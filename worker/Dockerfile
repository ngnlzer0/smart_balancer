# ==============================================================================
# Dockerfile: Control Plane Worker
# Призначення: Демон моніторингу, розрахунку EWMA-метрик та оновлення стану Redis.
# Увага: Контейнер вимагає доступу до Docker Socket.
# ==============================================================================

FROM python:3.11-slim


# Налаштування середовища виконання (Environment Variables).
# PYTHONDONTWRITEBYTECODE: Забороняє генерацію кеш-файлів .pyc.
# PYTHONUNBUFFERED: Вимикає буферизацію стандартних потоків виводу (stdout/stderr),
# що забезпечує миттєву доставку логів до системи збору метрик Docker.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /worker

# Стратегія кешування залежностей
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Імпорт модулів логіки та конфігурації
COPY worker.py config.py ./

# АРХІТЕКТУРНЕ РІШЕННЯ ЩОДО БЕЗПЕКИ:
# У цьому контейнері створення непривілейованого користувача навмисно пропущено.
# Процес виконується з правами 'root', оскільки для реалізації патерну
# Service Discovery воркеру необхідний доступ до сокета /var/run/docker.sock.
# За замовчуванням, доступ до цього сокета на хост-машині має лише група docker
# або root. Делегування прав у тестових та дослідницьких середовищах виконується
# через виконання процесу від імені суперкористувача всередині контейнера.

CMD ["python", "worker.py"]